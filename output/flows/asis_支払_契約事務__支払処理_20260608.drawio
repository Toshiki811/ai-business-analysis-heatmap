        <mxCell id="n02-doc-out" value="支払稟議書" style="shape=document;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontSize=10;fontColor=#334155;" vertex="1" parent="1"><mxGeometry x="170" y="412" width="140" height="44" as="geometry" /></mxCell>
        <mxCell id="n02-doc-out-edge" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;fontColor=#1f2937;strokeColor=#94a3b8;strokeWidth=1;dashed=1;dashPattern=3 3;endArrow=open;endFill=0;" edge="1" parent="1" source="n02" target="n02-doc-out"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n03" value="3. 請求書と納品書の照合&#xa;事務職員&#xa;請求書原本と納品書・発注内容を突合し、金額・数量・取引先を確認する&#xa;25分 / 負担: 高" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="100" y="578" width="200" height="86" as="geometry" /></mxCell>
        <mxCell id="n03-doc-in" value="請求書原本 納品書" style="shape=document;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontSize=10;fontColor=#334155;" vertex="1" parent="1"><mxGeometry x="88" y="524" width="140" height="44" as="geometry" /></mxCell>
        <mxCell id="n03-doc-in-edge" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;fontColor=#1f2937;strokeColor=#94a3b8;strokeWidth=1;dashed=1;dashPattern=3 3;endArrow=open;endFill=0;" edge="1" parent="1" source="n03-doc-in" target="n03"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n04" value="請求内容と納品内容が一致するか&#xa;照合結果の判定" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="105" y="720" width="190" height="104" as="geometry" /></mxCell>
        <mxCell id="n05" value="5. 取引先へ照会・修正依頼&#xa;事務職員&#xa;差異内容を取引先へ照会し、修正後の請求書を受領する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="100" y="880" width="200" height="86" as="geometry" /></mxCell>
        <mxCell id="n06" value="6. 支払情報の承認申請&#xa;事務職員&#xa;支払伝票を起票し、支払稟議書・請求書を添えて会計責任者へ回付する&#xa;15分 / 負担: 中" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="100" y="1080" width="200" height="86" as="geometry" /></mxCell>
        <mxCell id="n06-doc-in" value="支払稟議書 請求書原本" style="shape=document;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontSize=10;fontColor=#334155;" vertex="1" parent="1"><mxGeometry x="88" y="1026" width="140" height="44" as="geometry" /></mxCell>
        <mxCell id="n06-doc-in-edge" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;fontColor=#1f2937;strokeColor=#94a3b8;strokeWidth=1;dashed=1;dashPattern=3 3;endArrow=open;endFill=0;" edge="1" parent="1" source="n06-doc-in" target="n06"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n06-doc-out" value="支払伝票" style="shape=document;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontSize=10;fontColor=#334155;" vertex="1" parent="1"><mxGeometry x="170" y="1176" width="140" height="44" as="geometry" /></mxCell>
        <mxCell id="n06-doc-out-edge" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;strokeWidth=2;endArrow=block;endFill=1;fontSize=11;fontColor=#1f2937;strokeColor=#94a3b8;strokeWidth=1;dashed=1;dashPattern=3 3;endArrow=open;endFill=0;" edge="1" parent="1" source="n06" target="n06-doc-out"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n07" value="支払内容を承認するか&#xa;会計責任者の承認&#xa;【要確認(推定)】" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;dashed=1;dashPattern=4 4;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="355" y="1284" width="190" height="104" as="geometry" /></mxCell>
        <mxCell id="n08" value="8. 差戻し内容の修正&#xa;事務職員&#xa;指摘内容を修正し、再度承認申請を行う&#xa;【要確認(推定)】" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;dashPattern=4 4;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="100" y="1444" width="200" height="86" as="geometry" /></mxCell>
        <mxCell id="n09" value="9. 振込実行&#xa;出納職員&#xa;承認済み支払伝票をもとにインターネットバンキングで振込を実行する&#xa;20分 / 負担: 高" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="600" y="1644" width="200" height="86" as="geometry" /></mxCell>
        <mxCell id="n09-doc-in" value="支払伝票" style="shape=document;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontSize=10;fontColor=#334155;" vertex="1" parent="1"><mxGeometry x="588" y="1590" width="140" height="44" as="geometry" /></mxCell>
