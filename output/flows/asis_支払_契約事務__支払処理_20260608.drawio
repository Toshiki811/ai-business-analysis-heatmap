        <mxCell id="n09-doc-out" value="振込控" style="shape=document;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;fontSize=10;fontColor=#334155;" vertex="1" parent="1"><mxGeometry x="670" y="1740" width="140" height="44" as="geometry" /></mxCell>
