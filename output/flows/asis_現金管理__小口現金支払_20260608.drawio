        <mxCell id="m05" value="5. 通常の支払手続へ回付&#xa;事務職員&#xa;支払稟議による通常の支払処理に切り替える" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;strokeWidth=2;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="100" y="818" width="200" height="86" as="geometry" /></mxCell>
        <mxCell id="m06" value="6. 小口現金出納帳の記入&#xa;出納職員&#xa;支払内容を小口現金出納帳に記入し、残高を更新する&#xa;10分 / 負担: 中" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="350" y="960" width="200" height="86" as="geometry" /></mxCell>
