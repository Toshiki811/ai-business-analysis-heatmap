        <mxCell id="m02" value="2. 小口支払申請の受付&#xa;事務職員&#xa;小口現金支払申請書と領収書を受け付ける&#xa;10分 / 負担: 中" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="100" y="316" width="200" height="86" as="geometry" /></mxCell>
