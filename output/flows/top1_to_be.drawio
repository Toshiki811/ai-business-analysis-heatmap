        <mxCell id="s01" value="請求書・証憑の受領&#xa;Human&#xa;出納職員が取引先から請求書を受領し、スキャンして電子化する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="115" y="130" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s02" value="書類の自動読取り&#xa;AI&#xa;請求書PDF・納品書・稟議書・購入依頼書から金額・品目・支払先・期日を抽出する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="405" y="260" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s03" value="抽出信頼度の判定&#xa;抽出信頼度が閾値以上か" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="410" y="390" width="170" height="100" as="geometry" /></mxCell>
        <mxCell id="s04" value="書類間の自動突合&#xa;AI&#xa;請求書・稟議書・納品書の金額・品目・支払先を突合し、結果一覧を生成する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="405" y="520" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s05" value="突合結果の判定&#xa;金額・支払先・品目がすべて一致するか" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="410" y="650" width="170" height="100" as="geometry" /></mxCell>
        <mxCell id="s06" value="一致案件の確認&#xa;Human Review&#xa;出納職員が突合結果一覧をサンプリング確認し、支払情報を確定する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="695" y="780" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s07" value="支払承認&#xa;支払情報を承認するか" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="120" y="910" width="170" height="100" as="geometry" /></mxCell>
        <mxCell id="s08" value="不一致・低信頼案件の人手確認&#xa;Human Review&#xa;出納職員が不一致理由コメントと元書類を確認し、原因を特定する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="695" y="1040" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s09" value="取引先照会の要否判定&#xa;取引先への照会が必要か" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="120" y="1170" width="170" height="100" as="geometry" /></mxCell>
        <mxCell id="s10" value="振込データの自動生成&#xa;System&#xa;承認済み支払情報から総合振込データを自動生成する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="985" y="1300" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s11" value="取引先への照会・再受領&#xa;Human&#xa;取引先へ照会し、修正後の請求書を再受領して読取りからやり直す" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="115" y="1430" width="180" height="80" as="geometry" /></mxCell>
