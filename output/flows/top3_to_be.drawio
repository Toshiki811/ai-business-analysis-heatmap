        <mxCell id="s01" value="決算資料の収集・電子化&#xa;Human&#xa;出納職員が前期仕訳・減価償却計算表・棚卸集計表・保険証書等を収集し電子化する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="115" y="130" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s02" value="資料の自動読解&#xa;AI&#xa;収集資料から決算整理に必要な金額・期間・科目情報を抽出する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="405" y="260" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s03" value="仕訳下書きの生成&#xa;AI&#xa;当期の決算整理仕訳候補を科目・金額・根拠資料付きで下書きする" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="405" y="390" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s04" value="網羅性チェック&#xa;AI&#xa;前期仕訳カテゴリとの比較で作成漏れ候補を検出しチェックリストを生成する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="405" y="520" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s05" value="漏れ候補の有無判定&#xa;作成漏れ候補があるか" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="410" y="650" width="170" height="100" as="geometry" /></mxCell>
        <mxCell id="s06" value="漏れ候補の要否確認&#xa;Human Review&#xa;出納職員が漏れ候補の当期該当有無を確認し、必要な仕訳を追加する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="695" y="780" width="180" height="80" as="geometry" /></mxCell>
        <mxCell id="s07" value="仕訳下書きのレビュー&#xa;仕訳下書きを承認するか" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="700" y="910" width="170" height="100" as="geometry" /></mxCell>
