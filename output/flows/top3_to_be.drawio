        <mxCell id="s09" value="会計システムへの一括取込&#xa;System&#xa;承認済み仕訳をCSVで会計システムへ一括取込する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;strokeWidth=1;fontSize=11;fontColor=#000000;" vertex="1" parent="1"><mxGeometry x="985" y="1170" width="180" height="80" as="geometry" /></mxCell>
